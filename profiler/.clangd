CompileFlags:
  Add:
    - -DENABLE_OTEL
    - -std=c++17
    - -I/usr/include/c++/13
    - -I/usr/include/x86_64-linux-gnu/c++/13
    - -I/usr/include
    - -I/usr/local/include
  CompilationDatabase: build/

Diagnostics:
  UnusedIncludes: None
  MissingIncludes: Relaxed
  Suppress:
    - "-Wunused-includes"

InlayHints:
  Enabled: No
