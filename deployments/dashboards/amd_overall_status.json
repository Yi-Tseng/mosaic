      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "(max(avg_over_time((100 - (sum(rate(node_cpu_seconds_total{host=~\"$host\", mode=\"idle\"}[2m])) by (cpu, host) / sum(rate(node_cpu_seconds_total{host=~\"$host\"}[2m])) by (cpu, host)) * 100)[2m:]) - ((sum(avg_over_time((100 - (sum(rate(node_cpu_seconds_total{host=~\"$host\", mode=\"idle\"}[2m])) by (cpu, host) / sum(rate(node_cpu_seconds_total{host=~\"$host\"}[2m])) by (cpu, host)) * 100)[2m:])) - avg_over_time((100 - (sum(rate(node_cpu_seconds_total{host=~\"$host\", mode=\"idle\"}[2m])) by (cpu, host) / sum(rate(node_cpu_seconds_total{host=~\"$host\"}[2m])) by (cpu, host)) * 100)[2m:])) / (count(avg_over_time((100 - (sum(rate(node_cpu_seconds_total{host=~\"$host\", mode=\"idle\"}[2m])) by (cpu, host) / sum(rate(node_cpu_seconds_total{host=~\"$host\"}[2m])) by (cpu, host)) * 100)[2m:])) - 1))) > 10) * -1",
          "hide": false,
          "instant": true,
          "legendFormat": "",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Overall CPU Health",
      "type": "stat"
