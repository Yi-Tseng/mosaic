    {
      "datasource": {
        "type": "prometheus"
      },
      "description": "Overall CPU health status. Shows OK if CPU utilization is balanced across all CPUs, Error if any CPU is more than 10% greater than the average of all other CPUs.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "from": -0.0001,
                "result": {
                  "color": "red",
                  "index": 0,
                  "text": "Error"
                },
                "to": 999999
              },
              "type": "range"
            },
            {
              "options": {
                "match": "null",
                "result": {
                  "index": 1,
                  "text": "OK"
                }
              },
              "type": "special"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 0
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
