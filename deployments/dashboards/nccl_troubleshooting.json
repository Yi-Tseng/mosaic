{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Latency Overhead Analysis",
      "description": "Shows the latency overhead (from linear regression) for each rank pair. High values indicate communication bottlenecks.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "\u00b5s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "orange",
                "value": 100
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "nccl_profiler_rank_latency_microseconds_sum / nccl_profiler_rank_latency_microseconds_count",
          "legendFormat": "{{source_rank}} \u2192 {{dest_rank}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "lastNotNull",
            "max",
            "mean"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "sortBy": "Last *",
          "sortDesc": true
        }
      }
    },
    {
      "title": "Bandwidth Disparity (Coefficient of Variation)",
      "description": "Shows the variation in bandwidth across rank pairs. High variation indicates unbalanced network performance.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {},
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "orange",
                "value": 0.2
              },
              {
                "color": "red",
                "value": 0.3
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "stddev(nccl_profiler_rank_rate_MB_per_second_sum / nccl_profiler_rank_rate_MB_per_second_count) / avg(nccl_profiler_rank_rate_MB_per_second_sum / nccl_profiler_rank_rate_MB_per_second_count)",
          "legendFormat": "CV",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 10
      }
    },
    {
      "title": "Average Rank-to-Rank Latency",
      "description": "Average latency across all rank pairs.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "\u00b5s",
          "custom": {},
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg(nccl_profiler_rank_latency_microseconds_sum / nccl_profiler_rank_latency_microseconds_count)",
          "legendFormat": "Avg Latency",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 10
      }
    },
    {
      "title": "Average Rank-to-Rank Bandwidth",
      "description": "Average bandwidth across all rank pairs.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "MBs",
          "custom": {},
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "green",
                "value": 5000
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg(nccl_profiler_rank_rate_MB_per_second_sum / nccl_profiler_rank_rate_MB_per_second_count)",
          "legendFormat": "Avg BW",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 10
      }
    },
    {
      "title": "Slowest Rank Pairs (Bottom 5 by Bandwidth)",
      "description": "Identifies the 5 slowest rank pairs by bandwidth. Focus troubleshooting here.",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "unit",
                "value": "MBs"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": 0
                    },
                    {
                      "color": "yellow",
                      "value": 1000
                    },
                    {
                      "color": "green",
                      "value": 5000
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "bottomk(5, nccl_profiler_rank_rate_MB_per_second_sum / nccl_profiler_rank_rate_MB_per_second_count)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "job": true,
              "service_name": true
            },
            "renameByName": {
              "Value": "Bandwidth (MB/s)",
              "source_rank": "Source Rank",
              "dest_rank": "Dest Rank"
            }
          }
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      }
    },
